# Public app URL used for absolute URLs/metadata.
# In production, set this to your deployed origin (example: https://example.com).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel sets this automatically in deployments (development/preview/production).
# VERCEL_ENV=production

# Database (optional until Prisma is wired up)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Auth (optional until Clerk is wired up)
# CLERK_SECRET_KEY=
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
