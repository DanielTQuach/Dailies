// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProviderKey {
  GITHUB
  LEETCODE
  NEETCODE
  GENERIC_CUSTOM
  COMPETITIVE_PROGRAMMING
  MANUAL
}

enum DataSourceType {
  OFFICIAL_API
  OAUTH
  PUBLIC_PROFILE
  SCRAPE
  USER_UPLOAD
  MANUAL
}

enum SyncJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

model User {
  id                    String   @id @default(cuid())
  /// Clerk `userId` (`sub`). Nullable only for legacy rows before this column existed.
  clerkUserId           String?  @unique
  email                 String   @unique
  name                  String?
  onboardingCompleted   Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  goals                 Goal[]
  providerAccounts      ProviderAccount[]
  dailyActivities       DailyActivity[]
  providerSyncJobs      ProviderSyncJob[]
}

model ProviderAccount {
  id                 String          @id @default(cuid())
  userId             String
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider           ProviderKey
  externalId         String?
  displayName        String?
  accessToken        String?
  refreshToken       String?
  connectionStatus   String          @default("disconnected")
  dataSourceType     DataSourceType  @default(MANUAL)
  syncCadenceMinutes Int?            @default(360)
  confidenceLevel    Float           @default(0.8)
  lastSyncedAt       DateTime?
  metadata             Json?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@unique([userId, provider])
  @@index([userId])
}

model ProviderSyncJob {
  id         String          @id @default(cuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider   ProviderKey
  jobType    String
  status     SyncJobStatus   @default(PENDING)
  payload    Json?
  result     Json?
  error      String?
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime        @default(now())

  @@index([userId, status])
}

model DailyActivity {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime      @db.Date
  provider  ProviderKey
  points    Float         @default(0)
  completed Boolean       @default(false)
  meta      Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([userId, date, provider])
  @@index([userId, date])
}

model Goal {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  progressEntries ProgressEntry[]

  @@index([userId])
}

model ProgressEntry {
  id        String   @id @default(cuid())
  goalId    String
  goal      Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  amount    Int      @default(1)
  note      String?
  createdAt DateTime @default(now())

  @@index([goalId])
}
